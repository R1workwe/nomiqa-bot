# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic Claude API Key (получить на console.anthropic.com)
CLAUDE_API_KEY=your_anthropic_api_key_here

# Supabase (получить в Dashboard -> Project Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Системный промпт для бота (инструкции для AI)
SYSTEM_PROMPT=Ты корпоративный ассистент компании Nomiqa. Отвечай профессионально и по делу. Используй только русский язык.

# Telegram chat_id администратора (для команды /stats)
# Узнать свой chat_id можно у @userinfobot
ADMIN_CHAT_IDS=123456,896985504
